TRIANGULO DE FLOYD
import java.util.Scanner;
class TrianguloFloyd {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Introduzca el número de filas para el triángulo: ");
        int filas = sc.nextInt();
        
        int numeroSubida = 1;

        for (int i = 1; i <= filas; i++) {
            for (int j = 1; j <= i; j++) {
                System.out.print(numeroSubida + " ");
                numeroSubida++;
            }
            System.out.println(); 
        }
        sc.close();
    }
}
